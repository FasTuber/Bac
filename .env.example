# Copiază în `.env` și completează valorile.

# Baza de date SQLite (portabilă). Pentru Postgres: schimbă provider-ul în schema.prisma.
DATABASE_URL="file:./dev.db"

# Secret pentru semnarea sesiunilor JWT (generează: openssl rand -hex 32)
AUTH_SECRET="schimba-ma-cu-un-secret-aleator"

# OPȚIONAL — activează tutorele AI (Claude). Fără el, tutorele rulează în mod offline.
# ANTHROPIC_API_KEY="sk-ant-..."
# AI_MODEL="claude-sonnet-4-6"
